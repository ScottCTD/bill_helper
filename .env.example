# Bill Helper — environment variables
# Copy this file to one of:
#   ~/.config/bill-helper/.env   (shared across all worktrees — recommended)
#   .env                         (per-worktree override)
#
# Resolution order (highest → lowest priority):
#   1. Real environment variables  (production / CI)
#   2. .env in working directory   (per-worktree overrides)
#   3. ~/.config/bill-helper/.env  (shared dev secrets)

# ── Provider credentials (set the one matching your BILL_HELPER_AGENT_MODEL) ──
OPENROUTER_API_KEY=
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# GOOGLE_API_KEY=

# ── Observability (optional — enables LiteLLM → Langfuse tracing) ───────────
# LANGFUSE_PUBLIC_KEY=
# LANGFUSE_SECRET_KEY=
# LANGFUSE_HOST=https://us.cloud.langfuse.com

# ── Core (all have sensible defaults — override only if needed) ──────────────
# BILL_HELPER_DATA_DIR=~/.local/share/bill-helper
# BILL_HELPER_DATABASE_URL=sqlite:///~/.local/share/bill-helper/bill_helper.db
# BILL_HELPER_APP_NAME=Bill Helper
# BILL_HELPER_CORS_ORIGINS=["http://localhost:5173"]
# BILL_HELPER_CURRENT_USER_NAME=admin
# CURRENT_USER_TIMEZONE=America/Toronto
# DEFAULT_CURRENCY_CODE=CAD
# DASHBOARD_CURRENCY_CODE=CAD

# ── Agent ────────────────────────────────────────────────────────────────────
# BILL_HELPER_AGENT_MODEL=openrouter/qwen/qwen3.5-27b
# BILL_HELPER_AGENT_MAX_STEPS=100
# BILL_HELPER_AGENT_RETRY_MAX_ATTEMPTS=3
# BILL_HELPER_AGENT_RETRY_INITIAL_WAIT_SECONDS=0.25
# BILL_HELPER_AGENT_RETRY_MAX_WAIT_SECONDS=4.0
# BILL_HELPER_AGENT_RETRY_BACKOFF_MULTIPLIER=2.0
# BILL_HELPER_AGENT_MAX_IMAGE_SIZE_BYTES=5242880
# BILL_HELPER_AGENT_MAX_IMAGES_PER_MESSAGE=4
# BILL_HELPER_AGENT_BASE_URL=
# BILL_HELPER_AGENT_API_KEY=
